---
import Layout from "@/layouts/Layout.astro";
import { InvoicesPage } from "@/components/InvoicesPage";
import { listCompanies, getCompany } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";

const companies = await listCompanies();
const cookieCompanyId = Astro.cookies.get("companyId")?.value;
const selectedId = cookieCompanyId ? Number(cookieCompanyId) : companies[0]?.id;

const company = selectedId ? await getCompany(selectedId) : null;
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  <InvoicesPage
    client:load
    company={company}
    clients={clients}
    catalog={catalog}
    settings={settings}
  />
</Layout>
