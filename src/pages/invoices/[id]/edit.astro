---
import Layout from "@/layouts/Layout.astro";
import { InvoiceEditForm } from "@/components/invoices/InvoiceEditForm";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { getCompany } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { getInvoice } from "@/lib/invoices";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";
import { DOCUMENT_TYPE, INVOICE_STATUS } from "@/lib/documents";

const id = Number(Astro.params.id);
const invoice = Number.isInteger(id) && id > 0 ? await getInvoice(id) : null;
const validInvoice = invoice?.type === DOCUMENT_TYPE.INVOICE ? invoice : null;
if (validInvoice && validInvoice.status !== INVOICE_STATUS.DRAFT) {
  return Astro.redirect(`/invoices/${validInvoice.id}`);
}
const company = validInvoice ? await getCompany(validInvoice.companyId) : null;
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  {validInvoice && company ? (
    <InvoiceEditForm
      client:load
      company={company}
      clients={clients}
      catalog={catalog}
      settings={settings}
      invoice={validInvoice}
      documentType={DOCUMENT_TYPE.INVOICE}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Invoice not found.</AlertDescription>
    </Alert>
  )}
</Layout>
