---
import Layout from "@/layouts/Layout.astro";
import { InvoiceCreateForm } from "@/components/invoices/InvoiceCreateForm";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { getCompanyProfile } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";
import { DOCUMENT_TYPE } from "@/lib/documents";

const company = await getCompanyProfile();
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  {company ? (
    <InvoiceCreateForm
      client:load
      company={company}
      clients={clients}
      catalog={catalog}
      settings={settings}
      documentType={DOCUMENT_TYPE.INVOICE}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Set up the company profile first to start invoicing.</AlertDescription>
    </Alert>
  )}
</Layout>
