---
import Layout from "@/layouts/Layout.astro";
import { OfferCreateForm } from "@/components/offers/OfferCreateForm";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { getCompanyProfile } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";

const company = await getCompanyProfile();
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  {company ? (
    <OfferCreateForm
      client:load
      company={company}
      clients={clients}
      catalog={catalog}
      settings={settings}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Set up the company profile first to start making offers.</AlertDescription>
    </Alert>
  )}
</Layout>
