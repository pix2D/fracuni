---
import Layout from "@/layouts/Layout.astro";
import { OfferEditForm } from "@/components/offers/OfferEditForm";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { getCompany } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { getOffer } from "@/lib/offers";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";

const id = Number(Astro.params.id);
const offer = Number.isInteger(id) && id > 0 ? await getOffer(id) : null;
const company = offer ? await getCompany(offer.companyId) : null;
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  {offer && company ? (
    <OfferEditForm
      client:load
      company={company}
      clients={clients}
      catalog={catalog}
      settings={settings}
      offer={offer}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Offer not found.</AlertDescription>
    </Alert>
  )}
</Layout>
