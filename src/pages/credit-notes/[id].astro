---
import Layout from "@/layouts/Layout.astro";
import { InvoiceView } from "@/components/invoices/InvoiceView";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { getClient } from "@/lib/clients";
import { getCompany } from "@/lib/companies";
import { isDomestic } from "@/lib/countries";
import { DOCUMENT_TYPE, INVOICE_STATUS } from "@/lib/documents";
import { listEmailLogs } from "@/lib/email";
import { getExchangeRatePreview } from "@/lib/hnb";
import { getInvoice } from "@/lib/invoices";
import { determineTaxTreatment } from "@/lib/tax-engine";
import { getLatestViesVerification } from "@/lib/vies-verifications";

const id = Number(Astro.params.id);
const invoice = Number.isInteger(id) && id > 0 ? await getInvoice(id) : null;
const creditNote = invoice?.type === DOCUMENT_TYPE.CREDIT_NOTE ? invoice : null;
const company = creditNote ? await getCompany(creditNote.companyId) : null;
const client =
  creditNote?.clientId != null ? await getClient(creditNote.clientId) : null;
const [emailLogs, viesVerification] = creditNote
  ? await Promise.all([
      listEmailLogs(creditNote.id),
      getLatestViesVerification(creditNote.id),
    ])
  : [[], null];
const defaultLang = client && !isDomestic(client.country) ? "en" : "hr";
const viesRequired = client
  ? determineTaxTreatment({
      clientType: client.clientType,
      clientCountry: client.country,
      clientVatNumber: client.vatNumber,
    }) === "reverse-charge"
  : false;
const previewExchangeRate =
  creditNote?.status === INVOICE_STATUS.DRAFT
    ? await getExchangeRatePreview(creditNote.currency, creditNote.issueDate)
    : null;
---

<Layout>
  {creditNote && company ? (
    <InvoiceView
      client:load
      invoice={creditNote}
      documentType={DOCUMENT_TYPE.CREDIT_NOTE}
      defaultLang={defaultLang}
      viesRequired={viesRequired}
      viesVerification={viesVerification}
      emailLogs={emailLogs}
      previewExchangeRate={previewExchangeRate}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Credit Note not found.</AlertDescription>
    </Alert>
  )}
</Layout>
