---
import Layout from "@/layouts/Layout.astro";
import { InvoiceEditForm } from "@/components/invoices/InvoiceEditForm";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { getCompanyProfile } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { getInvoice } from "@/lib/invoices";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";
import { DOCUMENT_TYPE, INVOICE_STATUS } from "@/lib/documents";

const id = Number(Astro.params.id);
const invoice = Number.isInteger(id) && id > 0 ? await getInvoice(id) : null;
const creditNote = invoice?.type === DOCUMENT_TYPE.CREDIT_NOTE ? invoice : null;
if (creditNote && creditNote.status !== INVOICE_STATUS.DRAFT) {
  return Astro.redirect(`/credit-notes/${creditNote.id}`);
}
const company = creditNote ? await getCompanyProfile() : null;
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  {creditNote && company ? (
    <InvoiceEditForm
      client:load
      company={company}
      clients={clients}
      catalog={catalog}
      settings={settings}
      invoice={creditNote}
      documentType={DOCUMENT_TYPE.CREDIT_NOTE}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Credit note not found.</AlertDescription>
    </Alert>
  )}
</Layout>
