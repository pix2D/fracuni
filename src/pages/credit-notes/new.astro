---
import Layout from "@/layouts/Layout.astro";
import { InvoiceCreateForm } from "@/components/invoices/InvoiceCreateForm";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { listCompanies, getCompany } from "@/lib/companies";
import { listClients } from "@/lib/clients";
import { listCatalogEntries } from "@/lib/service-catalog";
import { getSettings } from "@/lib/settings";
import { DOCUMENT_TYPE } from "@/lib/documents";

const companies = await listCompanies();
const cookieCompanyId = Astro.cookies.get("companyId")?.value;
const selectedId = cookieCompanyId ? Number(cookieCompanyId) : companies[0]?.id;
const selectedCompanyId = selectedId !== undefined && Number.isInteger(selectedId) && selectedId > 0 ? selectedId : null;

const company = selectedCompanyId ? await getCompany(selectedCompanyId) : null;
const [clients, catalog, settings] = await Promise.all([
  listClients(),
  listCatalogEntries(),
  getSettings(),
]);
---

<Layout>
  {company ? (
    <InvoiceCreateForm
      client:load
      company={company}
      clients={clients}
      catalog={catalog}
      settings={settings}
      documentType={DOCUMENT_TYPE.CREDIT_NOTE}
    />
  ) : (
    <Alert variant="destructive">
      <AlertDescription>Select or create a Company first to create credit notes.</AlertDescription>
    </Alert>
  )}
</Layout>
