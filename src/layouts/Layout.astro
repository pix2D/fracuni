---
import "@/styles/global.css";
import { CompanySelector } from "@/components/CompanySelector";
import { DarkModeToggle } from "@/components/DarkModeToggle";
import { listCompanies } from "@/lib/companies";

const companies = await listCompanies();
const companyId = Astro.cookies.get("companyId")?.value;

const navLinks = [
  { href: "/invoices", label: "Invoices" },
  { href: "/credit-notes", label: "Credit Notes" },
  { href: "/offers", label: "Offers" },
  { href: "/clients", label: "Clients" },
  { href: "/companies", label: "Companies" },
  { href: "/settings", label: "Settings" },
];

const currentPath = Astro.url.pathname;
const navLinkBase =
  "inline-flex h-8 cursor-pointer items-center justify-center rounded-none border border-transparent px-2.5 text-xs font-medium transition-colors outline-none focus-visible:border-ring focus-visible:ring-1 focus-visible:ring-ring/50";
const navLinkActive = "bg-secondary text-secondary-foreground";
const navLinkInactive = "text-muted-foreground hover:bg-muted hover:text-foreground";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>FireRacuni</title>
    <script is:inline>
      if (localStorage.getItem("theme") === "dark") {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <header class="border-b border-border">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-6">
          <a href="/" class="text-lg font-semibold">FireRacuni</a>
          <nav class="hidden items-center gap-1 md:flex">
            {navLinks.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  navLinkBase,
                  currentPath.startsWith(href) ? navLinkActive : navLinkInactive,
                ]}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
        <div class="flex items-center gap-3">
          <CompanySelector client:load companies={companies} selectedId={companyId} />
          <DarkModeToggle client:load />
        </div>
      </div>
      <nav class="flex items-center gap-1 overflow-x-auto border-t border-border px-4 py-2 md:hidden">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              navLinkBase,
              "whitespace-nowrap",
              currentPath.startsWith(href) ? navLinkActive : navLinkInactive,
            ]}
          >
            {label}
          </a>
        ))}
      </nav>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>
  </body>
</html>
